{
  "Nina": {
    "BaseUrl": "http://localhost:1888",
    "ApiKey": ""
  },
  "Safety": {
    "PowerOutageConfirmedThresholdSeconds": 30
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs\\safety.log",
          "rollingInterval": "Day"
        }
      }
    ]
  }
}
