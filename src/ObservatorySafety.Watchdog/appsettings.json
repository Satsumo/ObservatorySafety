{
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs\\watcher.log",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "Watchdog": {
    "MainServiceName": "ObservatorySafety.Service",
    "ServiceCheckIntervalSeconds": 30,
    "MainServiceLogDirectory": "C:\\Users\\satsa\\OneDrive\\Development\\Projects\\ObservatorySafety\\src\\ObservatorySafety.Service\\logs",
    "MainServiceLogPattern": "safety*.log",
    "LogInactivityThresholdSeconds": 120,
    "LogCheckIntervalSeconds": 10,
    "AlertStrings": [
      "EXCEPTION",
      "POWER LOSS CONFIRMED",
      "SHUTDOWN FAILED",
      "NINA ERROR",
      "DOME CLOSE FAILURE",
      "MOUNT PARK FAILURE"
    ]
  },
  "AlertChannels": {
    "Pushover": {
      "Enabled": true,
      "UserKey": "YOUR_PUSHOVER_USER_KEY",
      "AppToken": "YOUR_PUSHOVER_APP_TOKEN_HERE"
    },
    "Email": {
      "Enabled": true,
      "SmtpServer": "YOUR_EMAIL_SMTP_PROVIDER_URL",
      "SmtpPort": 587,
      "UseTls": true,
      "Username": "YOUR_EMAIL_ADDRESS",
      "Password": "YOUR_EMAIL_APP_PASSWORD_HERE",
      "From": "YOUR_EMAIL_ADDRESS",
      "To": "EMAIL_ADDRESS_YOU_WANT_ALERT_TO_GO_TO"
    },
    "WhatsApp": {
      "Enabled": true,
      "TwilioSid": "YOUR_TWILIO_SID_HERE",
      "TwilioToken": "YOUR_TWILIO_TOKEN_HERE",
      "FromNumber": "whatsapp:+YOUR_TWILIO_WHATSAPP_NUMBER",
      "ToNumber": "whatsapp:+YOUR_PERSONAL_WHATSAPP_NUMBER"
    }
  }
}
