<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*" Name="Observatory Safety Watchdog" Language="1033"
           Version="1.0.0.0" Manufacturer="Satwant"
