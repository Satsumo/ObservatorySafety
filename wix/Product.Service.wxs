<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">

  <Product
      Id="*"
      Name="ObservatorySafety Service"
      Language="1033"
      Version="1.0.0.0"
      Manufacturer="Satsumo"
      UpgradeCode="A3F9C1E2-6B4D-4F8A-9C2E-1D7B3A9F4C21">

    <Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine" />
    <Media Id="1" Cabinet="product.cab" EmbedCab="yes" />

    <!-- REQUIRED ROOT DIRECTORY -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLDIR" Name="ObservatorySafety.Service" />
      </Directory>
    </Directory>

    <!-- Heat.exe harvested components -->
    <Feature Id="MainFeature" Title="ObservatorySafety Service" Level="1">
        <ComponentGroupRef Id="ServiceComponents" />
        <ComponentRef Id="ServiceInstaller" />
    </Feature>

    <!-- Windows Service installation -->
    <Component Id="ServiceInstaller" Directory="INSTALLDIR">
      <File Id="ServiceExe"
            Source="$(var.ServiceExePath)"
            KeyPath="yes" />

      <ServiceInstall
          Id="ObservatorySafetyServiceInstall"
          Name="ObservatorySafety.Service"
          DisplayName="Observatory Safety Service"
          Description="Monitors observatory safety conditions."
          Start="auto"
          Type="ownProcess"
          ErrorControl="normal"
          Vital="yes" />

      <ServiceControl
          Id="ObservatorySafetyServiceControl"
          Name="ObservatorySafety.Service"
          Start="install"
          Stop="both"
          Remove="uninstall"
          Wait="yes" />

      <!-- CORRECT WAY TO SET ENVIRONMENT VARIABLE IN WIX v3 -->
      <RegistryValue
          Root="HKLM"
          Key="SYSTEM\CurrentControlSet\Services\ObservatorySafety.Service"
          Name="Environment"
          Type="multiString"
          Value="OBSERVATORY_ENVIRONMENT=Production"
          Action="write" />

    </Component>

  </Product>
</Wix>
